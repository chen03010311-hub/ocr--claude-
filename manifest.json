{
  "manifest_version": 3,
  "name": "OCR Vocab",
  "version": "1.0.0",
  "description": "截图框选英文单词，GPT-4o-mini OCR 翻译，自动保存单词本",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "contextMenus",
    "scripting"
  ],

  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.siliconflow.cn/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "commands": {
    "activate-ocr": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "激活 OCR 截图选词模式"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "wordlist/wordlist.html",
        "settings/settings.html"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
